{
  "name": "luces-led-backend-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Backend TypeScript para MVP de luces LED",
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 dist/index.js",
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "lint": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-node.ps1 ./node_modules/tsx/dist/cli.mjs --test src/recommendation/application/resolve-recommendation-use-case.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.11",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
