# PostgreSQL
POSTGRES_DB=luces_led
POSTGRES_USER=admin_luces
POSTGRES_PASSWORD=admin_luces_change_me
DB_HOST=localhost
DB_PORT=5432

# App ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
CHATBOT_PORT=8001
ADMIN_USERNAME=admin
AUTH_SESSION_TTL_MINUTES=480

# Frontend API base URL
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Chatbot Python
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
BACKEND_API_BASE_URL=http://localhost:8080
CHAT_SESSION_TTL_MINUTES=30
CHAT_RATE_LIMIT_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_MAX_TOOL_ROUNDS=6

# Flyway (opcional)
FLYWAY_LOCATION_PRIMARY=filesystem:../database
FLYWAY_LOCATION_SECONDARY=filesystem:database

# Retencion de datos (backend)
RETENCION_ENABLED=false
RETENCION_CRON=0 0 3 * * *
RETENCION_DIAS_ANONIMIZAR=90
RETENCION_DIAS_ELIMINAR_RECOMENDACIONES=365
RETENCION_DIAS_ELIMINAR_CONSULTAS=540
RETENCION_NOMBRE_ANONIMO=ANONIMIZADO
RETENCION_TELEFONO_ANONIMO=0000000000
